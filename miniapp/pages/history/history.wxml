<view class="page">
  <view class="list-header" wx:if="{{list.length > 0}}">
    <text class="list-count">共 {{list.length}} 条记录</text>
    <button class="btn-secondary clear-btn" bindtap="clearAll">清空</button>
  </view>

  <view class="empty-state" wx:if="{{list.length === 0}}">
    <image class="empty-icon" src="data:image/png;base64,"></image>
    <text>暂无分析记录</text>
    <navigator url="/pages/index/index" class="btn-primary start-btn">开始分析</navigator>
  </view>

  <view class="history-list" wx:else>
    <view class="history-item" wx:for="{{list}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}" data-markdown="{{item.markdown}}">
      <view class="item-main">
        <text class="item-title text-ellipsis">{{item.title}}</text>
        <text class="item-time">{{item.time}}</text>
      </view>
      <view class="item-actions">
        <view class="star-btn {{item.starred ? 'starred' : ''}}" bindtap="toggleStar" data-id="{{item.id}}" catchtap>
          <text wx:if="{{item.starred}}">★</text>
          <text wx:else>☆</text>
        </view>
        <view class="del-btn" bindtap="deleteItem" data-id="{{item.id}}" catchtap>
          <text>🗑</text>
        </view>
      </view>
    </view>
  </view>
</view>
