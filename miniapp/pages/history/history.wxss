.page { min-height: 100vh; }

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px 4px;
}
.list-count {
  font-size: 13px;
  color: #636e72;
}
.clear-btn {
  font-size: 12px;
  padding: 4px 12px;
}

.empty-icon {
  width: 80px;
  height: 80px;
  margin-bottom: 8px;
}

.start-btn {
  width: 180px;
  margin-top: 16px;
  padding: 10px 0;
  font-size: 14px;
}

.history-list {
  padding: 8px 12px;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10px;
  padding: 14px 16px;
  margin-bottom: 8px;
  box-shadow: 0 1px 8px rgba(0,0,0,0.06);
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 15px;
  font-weight: 500;
  color: #2d3436;
  display: block;
  max-width: 200px;
}

.item-time {
  font-size: 12px;
  color: #b2bec3;
  display: block;
  margin-top: 4px;
}

.item-actions {
  display: flex;
  gap: 12px;
  flex-shrink: 0;
  margin-left: 12px;
}

.star-btn {
  font-size: 20px;
  color: #b2bec3;
  padding: 4px;
}

.star-btn.starred {
  color: #f1c40f;
}

.del-btn {
  font-size: 16px;
  color: #b2bec3;
  padding: 4px;
}
