<view class="page safe-bottom">
  <view class="card">
    <text class="section-title">服务器配置</text>
    <view class="form-item">
      <text class="form-label">服务器地址</text>
      <input class="form-input" placeholder="https://xxx-xxx.cloud.tencent.com" value="{{apiBaseUrl}}" bindinput="onApiBaseUrlInput" />
    </view>
    <text class="form-tip">输入微信云托管的默认域名，不要带结尾斜杠</text>
    <button class="btn-primary save-btn" bindtap="saveConfig">保存配置</button>
  </view>

  <view class="card">
    <text class="section-title">连接测试</text>
    <button class="btn-secondary" bindtap="testConnection" disabled="{{!apiBaseUrl}}">测试连接</button>
    <text class="test-result {{testResultType}}" wx:if="{{testResult}}">{{testResult}}</text>
  </view>

  <view class="card">
    <text class="section-title">关于</text>
    <view class="about-item">
      <text class="about-label">版本</text>
      <text class="about-value">1.0.0</text>
    </view>
    <view class="about-item">
      <text class="about-label">后端服务</text>
      <text class="about-value">{{statusText}}</text>
    </view>
  </view>
</view>
