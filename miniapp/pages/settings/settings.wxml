<view class="container">
  <view class="header">
    <text class="title">设置</text>
  </view>

  <view class="section">
    <view class="section-title">存储</view>
    <view class="info-row">
      <text class="info-label">本地缓存大小</text>
      <text class="info-value">{{storageSize}}</text>
    </view>
    <button class="btn-danger" bindtap="clearCache">清空本地历史记录</button>
  </view>

  <view class="section">
    <view class="section-title">云托管配置（真机模式）</view>
    <view class="info-row">
      <text class="info-label">环境 ID</text>
      <text class="info-value selectable">{{envId}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务名称</text>
      <text class="info-value selectable">{{serviceName}}</text>
    </view>
    <view class="form-tip">真机模式下将自动使用以上配置调用云托管后端（AI 分析）</view>
  </view>

  <view class="section">
    <button class="btn-secondary" bindtap="showAbout">关于</button>
  </view>

  <view class="footer">
    <text class="version">v{{version}} · 本地模拟模式</text>
  </view>
</view>
