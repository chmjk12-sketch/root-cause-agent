<view class="page safe-bottom">
  <view class="card">
    <text class="section-title">云托管配置</text>
    <view class="info-row">
      <text class="info-label">环境ID</text>
      <text class="info-value selectable">prod-d4gdb3koxd4c6f555</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务名称</text>
      <text class="info-value selectable">flask-1c4n</text>
    </view>
    <text class="form-tip">使用微信云托管内部通信，无需公网域名和备案</text>
  </view>

  <view class="card">
    <text class="section-title">连接测试</text>
    <button class="btn-secondary" bindtap="testConnection">测试后端连通性</button>
    <text class="test-result {{testResultType}}" wx:if="{{testResult}}">{{testResult}}</text>
  </view>

  <view class="card">
    <text class="section-title">关于</text>
    <view class="about-item">
      <text class="about-label">版本</text>
      <text class="about-value">1.0.0-cloud</text>
    </view>
    <view class="about-item">
      <text class="about-label">通信方式</text>
      <text class="about-value">云托管内部通信</text>
    </view>
  </view>
</view>
