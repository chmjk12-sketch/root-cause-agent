.page { padding-bottom: 40px; }

.header {
  padding: 24px 20px 12px;
}
.header-title {
  font-size: 24px;
  font-weight: 700;
  color: #1565c0;
}
.header-desc {
  display: block;
  font-size: 14px;
  color: #636e72;
  margin-top: 6px;
}

.card {
  background: #ffffff;
  border-radius: 12px;
  margin: 12px 16px;
  padding: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}

.input-area {
  width: 100%;
  min-height: 150px;
  font-size: 15px;
  line-height: 1.6;
  color: #2d3436;
  border: none;
  outline: none;
  padding: 0;
  font-family: inherit;
  box-sizing: border-box;
}

.input-count {
  text-align: right;
  font-size: 12px;
  color: #b2bec3;
  margin: 4px 0 12px;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.btn-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.tips {
  margin: 16px 16px 0;
  padding: 16px;
  background: #e6f1fb;
  border-radius: 12px;
}

.tips-title {
  font-size: 14px;
  font-weight: 600;
  color: #1565c0;
  margin-bottom: 10px;
  display: block;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8px;
}

.tip-num {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #2979ff;
  color: #fff;
  font-size: 11px;
  text-align: center;
  line-height: 18px;
  margin-right: 10px;
  flex-shrink: 0;
}

.tip-text {
  font-size: 13px;
  color: #2d3436;
  line-height: 1.5;
}
